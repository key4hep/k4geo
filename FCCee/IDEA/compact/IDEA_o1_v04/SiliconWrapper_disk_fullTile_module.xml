<!-- 
    Sensor components of the silicon wrapper disk half-tile module (with three sensor modules in z). Multiple sensors are grouped into a 'module' to reduce the number of module IDs needed. 
-->
<lccdd>
    <!-- First module on top -->
    <component name="Left quad"  sensitive="True" ymin="-SiWr_mod_z/2.+SiWr_mod_z_periphery-2.5*(SiWr_mod_z-SiWr_mod_overlap)" ymax="SiWr_mod_z/2.-2.5*(SiWr_mod_z-SiWr_mod_overlap)" xmin="-SiWr_mod_rphi/2." xmax="-SiWr_mod_quad_spacing/2." vis="SiWrSensitiveVis"/> <!-- Left quad -->
